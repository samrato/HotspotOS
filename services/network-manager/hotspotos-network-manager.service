[Unit]
Description=HotspotOS Network Manager
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/home/activator/HotspotOS/services/network-manager
ExecStart=/home/activator/HotspotOS/services/network-manager/network-manager -simulate=true
Restart=always
RestartSec=5
Environment=PORT=8081

[Install]
WantedBy=multi-user.target
